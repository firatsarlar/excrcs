{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build asset_scraper (debug)",
      "detail": "Compile c1.cpp with debug symbols (-g) into dist/",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "mkdir -p dist && g++ -std=c++20 -g -O0 c1.cpp -o dist/asset_scraper"
      ],
      "options": {
        "cwd": "${workspaceFolder}/d"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}