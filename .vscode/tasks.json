{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build asset_scraper (debug)",
      "detail": "Compile c1.cpp with debug symbols (-g)",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++20",
        "-g",
        "-O0",
        "c1.cpp",
        "-o",
        "asset_scraper"
      ],
      "options": {
        "cwd": "${workspaceFolder}/d"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}